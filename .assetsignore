# Files that must never be served as static assets
# The git repo — MUST be blocked, or /.git/* leaks full source + history.
.git
.git/**
src
wrangler.jsonc
schema.sql
serve.js
site.js.map
package.json
package-lock.json
node_modules
README.md
COMPLIANCE_NOTES.md
.gitignore
.assetsignore
.claude
.wrangler
.dev.vars
